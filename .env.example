# String de conexão do PostgreSQL (Railway fornece automaticamente)
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# SSL: deixe ligado em produção (Railway). Em ambiente local sem SSL, use false.
DATABASE_SSL=true

# Porta (Railway define sozinho; localmente pode usar 4000)
PORT=4000

# (Opcional) URL do frontend para restringir CORS. Ex.: https://seuapp.vercel.app
# FRONTEND_URL=

# (Opcional) Chave de acesso. Se definida, o frontend precisa enviar o mesmo valor.
# API_KEY=uma-senha-secreta-bem-grande
